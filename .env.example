# DataCanvas Environment Variables
# Copy this file to .env.local and fill in the values

# Neon Database (Serverless PostgreSQL)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/datacanvas?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/datacanvas?sslmode=require"

# NextAuth.js
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_ID=""
GITHUB_SECRET=""
